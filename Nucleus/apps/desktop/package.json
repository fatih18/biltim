{
	"name": "desktop",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"build": "bun build --minify-whitespace --minify-syntax --target bun --outdir dist ./src/index.ts",
		"build:compile:linux-x64": "bun build --compile --minify-whitespace --minify-syntax --target bun-linux-x64 --outfile dist/desktop-agent-linux-x64 ./src/index.ts",
		"build:compile:windows-x64": "bun build --compile --minify-whitespace --minify-syntax --target bun-windows-x64 --outfile dist/desktop-agent-windows-x64.exe ./src/index.ts",
		"build:compile:mac-arm64": "bun build --compile --minify-whitespace --minify-syntax --target bun-darwin-arm64 --outfile dist/desktop-agent-macos-arm64 ./src/index.ts",
		"build:compile:all": "bun run build:compile:linux-x64 && bun run build:compile:windows-x64 && bun run build:compile:mac-arm64",
		"build:dist": "bun run scripts/build-for-distribution.ts"
	},
	"dependencies": {
		"elysia": "latest"
	},
	"devDependencies": {
		"@monorepo/configs": "workspace:*",
		"bun-types": "latest"
	}
}
